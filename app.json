{
  "expo": {
    "name": "Invoiça",
    "slug": "invoca",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "invoica",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splsh.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E7D36"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.invoica.app",
      "infoPlist": {
        "CFBundleDisplayName": "Invoiça"
      }
    },
    "android": {
      "package": "com.invoica.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#0E7D36"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
