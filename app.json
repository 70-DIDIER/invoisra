{
  "expo": {
    "name": "Invoisra",
    "slug": "invosra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/splash.png",
    "scheme": "invoisra",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E7D36"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.invoisra.app",
      "infoPlist": {
        "CFBundleDisplayName": "Invoisra"
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.invoisra.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/splash.png",
        "backgroundColor": "#0E7D36"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0E7D36",
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "image": "./assets/images/logo.png",
            "backgroundColor": "#0E7D36"
          }
        }
      ],
      "./plugins/withDisableSplashScreenDim",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
